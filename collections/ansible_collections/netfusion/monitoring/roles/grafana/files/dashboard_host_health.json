{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [
    {
      "title": "Proxmox Cluster Overview",
      "type": "dashboards",
      "tags": ["netfusion", "proxmox"],
      "asDropdown": false,
      "includeVars": true,
      "keepTime": true
    }
  ],
  "panels": [
    {
      "type": "bargauge",
      "title": "Exporter Health - Proxmox Nodes",
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "max by(instance_name) (up{job=\"node_exporter\", instance_name=~\"nft-pve.*\"})",
          "legendFormat": "{{instance_name}}",
          "instant": true,
          "refId": "A"
        }
      ],
      "options": {
        "displayMode": "basic",
        "orientation": "vertical",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showUnfilled": true
      },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DOWN", "color": "red" },
                "1": { "text": "UP", "color": "green" }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "links": [
            {
              "title": "Filter dashboard to host",
              "url": "/d/host-health-overview/host-health-overview?var-host=${__field.labels.instance_name}&from=${__from}&to=${__to}"
            }
          ]
        },
        "overrides": []
      }
    },
    {
      "type": "bargauge",
      "title": "Exporter Health - Monitoring/Core",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 7 },
      "targets": [
        {
          "expr": "max by(instance_name) (up{job=\"node_exporter\", instance_name=~\"prometheus|prometheus-alertmanager|grafana|postgresql|nft-monitor\"})",
          "legendFormat": "{{instance_name}}",
          "instant": true,
          "refId": "A"
        }
      ],
      "options": {
        "displayMode": "basic",
        "orientation": "vertical",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showUnfilled": true
      },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DOWN", "color": "red" },
                "1": { "text": "UP", "color": "green" }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "bargauge",
      "title": "Exporter Health - Guests / Other Services",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 7 },
      "targets": [
        {
          "expr": "max by(instance_name) (up{job=\"node_exporter\", instance_name!~\"nft-pve.*|prometheus|prometheus-alertmanager|grafana|postgresql|bluestar\"})",
          "legendFormat": "{{instance_name}}",
          "instant": true,
          "refId": "A"
        }
      ],
      "options": {
        "displayMode": "basic",
        "orientation": "vertical",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showUnfilled": true
      },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DOWN", "color": "red" },
                "1": { "text": "UP", "color": "green" }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "CPU Usage %",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "targets": [
        {
          "expr": "100 - (avg by(instance_name) (rate(node_cpu_seconds_total{mode=\"idle\", instance_name=~\"$host\"}[5m])) * 100)",
          "legendFormat": "{{instance_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "links": [
            {
              "title": "Filter dashboard to host",
              "url": "/d/host-health-overview/host-health-overview?var-host=${__field.labels.instance_name}&from=${__from}&to=${__to}"
            }
          ]
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } }
    },
    {
      "type": "timeseries",
      "title": "Memory Usage %",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "targets": [
        {
          "expr": "100 * (1 - (avg by(instance_name) (node_memory_MemAvailable_bytes{instance_name=~\"$host\"}) / avg by(instance_name) (node_memory_MemTotal_bytes{instance_name=~\"$host\"})))",
          "legendFormat": "{{instance_name}}",
          "refId": "A"
        }
      ],
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } }
    },
    {
      "type": "timeseries",
      "title": "Root FS Used %",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "targets": [
        {
          "expr": "max by(instance_name) (100 * (1 - (node_filesystem_avail_bytes{mountpoint=\"/\",fstype!~\"tmpfs|overlay\",instance_name=~\"$host\"} / node_filesystem_size_bytes{mountpoint=\"/\",fstype!~\"tmpfs|overlay\",instance_name=~\"$host\"})))",
          "legendFormat": "{{instance_name}}",
          "refId": "A"
        }
      ],
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } }
    },
    {
      "type": "timeseries",
      "title": "Load Average (5m)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
      "targets": [
        {
          "expr": "max by(instance_name) (node_load5{instance_name=~\"$host\"})",
          "legendFormat": "{{instance_name}}",
          "refId": "A"
        }
      ],
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } }
    },
    {
      "type": "timeseries",
      "title": "Network RX Bytes/sec",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 30 },
      "targets": [
        {
          "expr": "sum by(instance_name) (rate(node_network_receive_bytes_total{device!=\"lo\",instance_name=~\"$host\"}[5m]))",
          "legendFormat": "{{instance_name}}",
          "refId": "A"
        }
      ],
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } }
    },
    {
      "type": "timeseries",
      "title": "Network TX Bytes/sec",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 30 },
      "targets": [
        {
          "expr": "sum by(instance_name) (rate(node_network_transmit_bytes_total{device!=\"lo\",instance_name=~\"$host\"}[5m]))",
          "legendFormat": "{{instance_name}}",
          "refId": "A"
        }
      ],
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } }
    },
    {
      "type": "state-timeline",
      "title": "Exporter State Over Time",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 38 },
      "targets": [
        {
          "expr": "up{job=\"node_exporter\",instance_name=~\"$host\"}",
          "legendFormat": "{{instance_name}}",
          "refId": "A"
        }
      ],
      "options": {
        "mergeValues": true,
        "showValue": "never",
        "rowHeight": 0.95,
        "pageSize": 40
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DOWN", "color": "red" },
                "1": { "text": "UP", "color": "green" }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["netfusion", "hosts"],
  "templating": {
    "list": [
      {
        "name": "host",
        "type": "query",
        "label": "Host",
        "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
        "definition": "label_values(up{job=\"node_exporter\"}, instance_name)",
        "query": { "query": "label_values(up{job=\"node_exporter\"}, instance_name)", "refId": "StandardVariableQuery" },
        "includeAll": true,
        "allValue": ".*",
        "multi": false,
        "current": { "text": "All", "value": ".*" },
        "refresh": 1
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timezone": "browser",
  "title": "Host Health Overview",
  "uid": "host-health-overview",
  "version": 3
}
