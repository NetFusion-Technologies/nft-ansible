{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "panels": [
    {
      "type": "timeseries",
      "title": "Targets Up",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum by (job) (up)",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "CPU Usage %",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "100 - (avg by(instance_name)(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "{{instance_name}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Memory Usage %",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "100 * (1 - (avg by(instance_name) (node_memory_MemAvailable_bytes) / avg by(instance_name) (node_memory_MemTotal_bytes)))",
          "legendFormat": "{{instance_name}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Root Filesystem Used %",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "100 * (1 - (node_filesystem_avail_bytes{mountpoint=\"/\",fstype!~\"tmpfs|overlay\"} / node_filesystem_size_bytes{mountpoint=\"/\",fstype!~"tmpfs|overlay\"}))",
          "legendFormat": "{{instance_name}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Proxmox Targets Up",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "max by(instance_name) (up{job=\"proxmox_pve_exporter\"})",
          "legendFormat": "{{instance_name}}"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["netfusion", "infrastructure"],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timezone": "browser",
  "title": "Infrastructure Overview",
  "version": 1
}
