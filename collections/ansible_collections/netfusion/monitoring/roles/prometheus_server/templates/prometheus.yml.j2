global:
  scrape_interval: {{ prometheus_scrape_interval }}
  evaluation_interval: {{ prometheus_evaluation_interval }}
  external_labels:
{% for k, v in monitoring_prometheus_external_labels.items() %}
    {{ k }}: '{{ v }}'
{% endfor %}

alerting:
  alertmanagers:
    - static_configs:
        - targets:
            - '{{ hostvars[monitoring_alertmanager_host].ansible_host | default(monitoring_alertmanager_host) }}:9093'

rule_files:
  - {{ prometheus_rules_dir }}/*.yml

scrape_configs:
  - job_name: prometheus
    static_configs:
      - targets:
          - '{{ hostvars[monitoring_prometheus_host].ansible_host | default(monitoring_prometheus_host) }}:9090'
        labels:
          instance_name: '{{ monitoring_prometheus_host }}'
          job_group: monitoring
    relabel_configs:
      - source_labels: [__address__]
        target_label: scrape_target
      - source_labels: [instance_name]
        target_label: instance

  - job_name: alertmanager
    static_configs:
      - targets:
          - '{{ hostvars[monitoring_alertmanager_host].ansible_host | default(monitoring_alertmanager_host) }}:9093'
        labels:
          instance_name: '{{ monitoring_alertmanager_host }}'
          job_group: monitoring
    relabel_configs:
      - source_labels: [__address__]
        target_label: scrape_target
      - source_labels: [instance_name]
        target_label: instance

{% if monitoring_enable_node_exporter %}
  - job_name: node_exporter
    static_configs:
{% for h in groups['managed_linux'] | default([]) %}
      - targets:
          - '{{ hostvars[h].ansible_host | default(h) }}:{{ prometheus_node_exporter_port }}'
        labels:
          instance_name: '{{ h }}'
          job_group: linux
{% endfor %}
    relabel_configs:
      - source_labels: [__address__]
        target_label: scrape_target
      - source_labels: [instance_name]
        target_label: instance
{% endif %}

{% if monitoring_enable_proxmox_scrape %}
  - job_name: proxmox_pve_exporter
    metrics_path: /metrics
    static_configs:
{% for h in groups['proxmox_nodes'] | default([]) %}
      - targets:
          - '{{ hostvars[h].ansible_host | default(h) }}:{{ prometheus_pve_exporter_port }}'
        labels:
          instance_name: '{{ h }}'
          proxmox_node: '{{ h }}'
          job_group: proxmox
{% endfor %}
    relabel_configs:
      - source_labels: [__address__]
        target_label: scrape_target
      - source_labels: [instance_name]
        target_label: instance

  - job_name: proxmox_pve_cluster
    metrics_path: /pve
    params:
      cluster: ['1']
      node: ['1']
    static_configs:
      - targets:
          - '{{ hostvars["nft-pve4"].ansible_host | default("nft-pve4") }}:{{ prometheus_pve_exporter_port }}'
        labels:
          instance_name: 'nft-pve4'
          proxmox_node: 'nft-pve4'
          job_group: proxmox
          scrape_scope: cluster
    relabel_configs:
      - source_labels: [__address__]
        target_label: scrape_target
      - source_labels: [instance_name]
        target_label: instance
{% endif %}

{% if monitoring_enable_netdata_scrape and 'iRedMail' in (groups['managed_linux'] | default([])) %}
  - job_name: netdata
    metrics_path: /api/v1/allmetrics
    params:
      format: ['prometheus']
    static_configs:
      - targets:
          - '{{ hostvars["iRedMail"].ansible_host | default("iRedMail") }}:{{ prometheus_netdata_port }}'
        labels:
          instance_name: 'iRedMail-netdata'
          job_group: mail
    relabel_configs:
      - source_labels: [__address__]
        target_label: scrape_target
      - source_labels: [instance_name]
        target_label: instance
{% endif %}
